# Groq API
GROQ_API_KEY=

# LLM model IDs — do not change unless Groq renames these
PRIMARY_LLM=llama-3.3-70b-versatile
FALLBACK_LLM=llama-3.1-8b-instant

# Contradiction detection
CONTRADICTION_THRESHOLD=0.75
NLI_TIMEOUT_SECONDS=30.0
MAX_NLI_PAIRS=50

# Vector store: "chromadb" for dev, "qdrant" for prod
VECTOR_STORE_BACKEND=chromadb
QDRANT_URL=
QDRANT_API_KEY=
CHROMA_PERSIST_DIR=./chroma_db

# Relational DB: "sqlite" for dev, "postgresql" for prod
DB_BACKEND=sqlite
DATABASE_URL=sqlite:///./sec_rag.db

# Ingestion
TICKERS_CONFIG=./config/tickers.json
